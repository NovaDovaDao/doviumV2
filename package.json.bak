{
  "name": "solana-defi-toolkit",
  "version": "1.0.0",
  "description": "A TypeScript toolkit for Solana DeFi operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start:pump-fun-bot": "ts-node scripts/pump-fun-bot.ts",
    "start:token-listener-bot": "ts-node scripts/tokenListener.ts",
    "start:volume-bot": "ts-node scripts/run-bot.ts",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.30.1",
    "@solana/spl-token": "0.4.9",
    "@solana/web3.js": "1.95.8",
    "bignumber.js": "9.1.2",
    "bs58": "6.0.0",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
